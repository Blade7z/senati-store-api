# Variables de entorno para SENATI Store API
# Copia este archivo como .env y completa con tus valores reales

# Puerto del servidor
PORT=3000

# Conexión a MongoDB Atlas
# Obtén esta URL desde MongoDB Atlas > Connect > Connect your application
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/?appName=nombre-app

# Clave secreta para JWT (cambia esto por una clave segura)
JWT_SECRET=tu_clave_secreta_super_segura_12345

# Entorno de desarrollo
NODE_ENV=development